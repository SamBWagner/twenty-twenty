---
interface Props {
  title: string;
}

import { cn, scrapbookButton } from "../lib/button-styles";
import Footer from "../components/Footer.astro";
import TearStrip from "../components/TearStrip.astro";
import BrandLink from "../components/react/BrandLink";

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Twenty Twenty</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=The+Girl+Next+Door&family=Space+Grotesk:wght@400;500;600;700&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <style>
      .text-stroke {
        -webkit-text-stroke: 3px #080708;
        paint-order: stroke fill;
      }
      .text-stroke-sm {
        -webkit-text-stroke: 2px #080708;
        paint-order: stroke fill;
      }
      .tape {
        position: relative;
      }
      .tape::before {
        content: "";
        position: absolute;
        top: -8px;
        left: 50%;
        transform: translateX(-50%) rotate(-2deg);
        width: 80px;
        height: 24px;
        background: rgba(253, 202, 64, 0.7);
        border: 2px solid #080708;
        z-index: 10;
      }
      /* Marching ants animation */
      @keyframes march {
        to {
          stroke-dashoffset: -24;
        }
      }

      /* Button click press-down */
      .btn-pressing {
        transform: translate(1px, 2px) scale(0.99) !important;
        transition: transform 0.08s ease-out !important;
      }

      /* Slide-in overlay */
      @keyframes slide-from-left {
        from { transform: translateX(-100%); }
        to { transform: translateX(0); }
      }
      @keyframes slide-from-right {
        from { transform: translateX(100%); }
        to { transform: translateX(0); }
      }
      @keyframes slide-from-top {
        from { transform: translateY(-100%); }
        to { transform: translateY(0); }
      }
      @keyframes slide-from-bottom {
        from { transform: translateY(100%); }
        to { transform: translateY(0); }
      }
      .click-overlay {
        position: absolute;
        inset: 0;
        z-index: 1;
        pointer-events: none;
      }
      .click-overlay-text {
        position: relative;
        z-index: 2;
      }
      .paper-tear {
        clip-path: polygon(0% 0%, 3% 2%, 6% 0%, 9% 1%, 12% 0%, 15% 2%, 18% 0%, 21% 1%, 24% 0%, 27% 2%, 30% 0%, 33% 1%, 36% 0%, 39% 2%, 42% 0%, 45% 1%, 48% 0%, 51% 2%, 54% 0%, 57% 1%, 60% 0%, 63% 2%, 66% 0%, 69% 1%, 72% 0%, 75% 2%, 78% 0%, 81% 1%, 84% 0%, 87% 2%, 90% 0%, 93% 1%, 96% 0%, 100% 2%, 100% 100%, 0% 100%);
      }

      /* Floating avatar animations */
      @keyframes float-0 {
        0%, 100% { transform: translate(0, 0) rotate(0deg); }
        25% { transform: translate(25vw, 12vh) rotate(5deg); }
        50% { transform: translate(40vw, 35vh) rotate(-3deg); }
        75% { transform: translate(15vw, 50vh) rotate(8deg); }
      }
      @keyframes float-1 {
        0%, 100% { transform: translate(0, 0) rotate(0deg); }
        25% { transform: translate(-20vw, 25vh) rotate(-6deg); }
        50% { transform: translate(10vw, 50vh) rotate(4deg); }
        75% { transform: translate(-15vw, 20vh) rotate(-2deg); }
      }
      @keyframes float-2 {
        0%, 100% { transform: translate(0, 0) rotate(0deg); }
        33% { transform: translate(30vw, -10vh) rotate(7deg); }
        66% { transform: translate(-10vw, 30vh) rotate(-5deg); }
      }
      @keyframes float-3 {
        0%, 100% { transform: translate(0, 0) rotate(0deg); }
        20% { transform: translate(-25vw, 15vh) rotate(-4deg); }
        40% { transform: translate(5vw, 40vh) rotate(6deg); }
        60% { transform: translate(20vw, 20vh) rotate(-8deg); }
        80% { transform: translate(-5vw, -5vh) rotate(3deg); }
      }
    </style>
    <style is:global>
      :root {
        --note-border: #080708;
      }

      @keyframes section-bounce {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-6px); }
      }

      .section-bounce {
        animation: section-bounce 1s ease-in-out infinite;
      }

      .scribble-text {
        font-family: "The Girl Next Door", cursive;
      }

      .scribble-help {
        font-family: "The Girl Next Door", cursive;
        font-size: clamp(1.05rem, 1rem + 0.25vw, 1.35rem);
        font-weight: 700;
        letter-spacing: 0.025em;
        line-height: 1.2;
      }

      input::placeholder,
      textarea::placeholder {
        font-family: "The Girl Next Door", cursive;
        font-weight: 700;
        font-size: 1.18em;
        letter-spacing: 0.025em;
        line-height: 1.15;
        opacity: 1;
      }

      .scrapbook-btn {
        --sb-rest-rotate: 0deg;
        --sb-hover-rotate: 0.45deg;
        --sb-base-shadow-x: 2px;
        --sb-base-shadow-y: 2px;
        --sb-hover-shadow-x: 5px;
        --sb-hover-shadow-y: 5px;
        --sb-shadow-color: #080708;
        --sb-hover-shadow-color: #3772FF;
        --sb-lift-x: -1px;
        --sb-lift-y: -2px;
        box-shadow: var(--sb-base-shadow-x) var(--sb-base-shadow-y) 0 0 var(--sb-shadow-color);
        transform: rotate(var(--sb-rest-rotate));
        transform-origin: center;
        transition:
          transform 160ms cubic-bezier(0.22, 1, 0.36, 1),
          box-shadow 160ms cubic-bezier(0.22, 1, 0.36, 1),
          background-color 140ms ease,
          color 140ms ease,
          border-color 140ms ease;
        will-change: transform, box-shadow;
        text-decoration: none;
      }

      .scrapbook-btn:hover:not(:disabled):not([aria-disabled="true"]),
      .scrapbook-btn:focus-visible:not(:disabled):not([aria-disabled="true"]) {
        transform: translate(var(--sb-lift-x), var(--sb-lift-y)) rotate(var(--sb-hover-rotate));
        box-shadow: var(--sb-hover-shadow-x) var(--sb-hover-shadow-y) 0 0 var(--sb-hover-shadow-color);
      }

      .scrapbook-btn:focus-visible {
        outline: 2px solid #080708;
        outline-offset: 2px;
      }

      .scrapbook-btn:disabled,
      .scrapbook-btn[aria-disabled="true"] {
        cursor: not-allowed;
        opacity: 0.55;
        transform: rotate(var(--sb-rest-rotate));
        box-shadow: var(--sb-base-shadow-x) var(--sb-base-shadow-y) 0 0 var(--sb-shadow-color);
      }

      .scrapbook-btn--neutral {
        --sb-hover-shadow-color: #3772FF;
      }

      .scrapbook-btn--primary,
      .scrapbook-btn--secondary {
        --sb-hover-shadow-color: #FDCA40;
      }

      .scrapbook-btn--warm {
        --sb-hover-shadow-color: #3772FF;
      }

      .scrapbook-btn--danger {
        --sb-hover-shadow-color: #F87171;
      }

      .scrapbook-btn--success {
        --sb-hover-shadow-color: #34D399;
      }

      .scrapbook-btn--sun {
        --sb-hover-shadow-color: #f4c953;
      }

      .scrapbook-btn--lavender {
        --sb-hover-shadow-color: #c1a5ff;
      }

      .scrapbook-btn--peach {
        --sb-hover-shadow-color: #ffae5c;
      }

      .scrapbook-btn--plum {
        --sb-hover-shadow-color: #9760f3;
      }

      .scrapbook-btn--mint {
        --sb-hover-shadow-color: #66d98d;
      }

      .scrapbook-btn--blush {
        --sb-hover-shadow-color: #ff97ba;
      }

      .scrapbook-btn--cobalt {
        --sb-hover-shadow-color: #5f82f9;
      }

      .note-shell {
        --note-bg: #fffdf7;
        --note-surface: #fffefb;
        --note-panel: #fffefb;
        --note-accent: #ffffff;
        --note-chip: #ffffff;
        --note-inset: #fffefb;
        --note-row: #fffefb;
        --note-tape: rgba(253, 202, 64, 0.72);
        --note-ink: #080708;
        --note-muted: rgba(8, 7, 8, 0.64);
        position: relative;
        overflow: visible;
        color: var(--note-ink);
        border: 3px solid var(--note-border);
        background-color: var(--note-bg);
      }

      .note-shell[data-tape-position]::before {
        content: "";
        position: absolute;
        z-index: 1;
        border: 2px solid var(--note-border);
        background: var(--note-tape);
        box-shadow: 2px 2px 0 0 rgba(8, 7, 8, 0.12);
      }

      .note-shell[data-tape-position="top-center"]::before {
        top: 0;
        left: 50%;
        width: 5.5rem;
        height: 1.6rem;
        transform: translate(-50%, -56%) rotate(-3deg);
      }

      .note-shell[data-tape-position="top-right"]::before {
        top: 0.35rem;
        right: 1.5rem;
        width: 4.75rem;
        height: 1.45rem;
        transform: translateY(-78%) rotate(8deg);
      }

      .note-shell[data-tape-position="side-left"]::before {
        left: 0;
        top: 2.1rem;
        width: 1.55rem;
        height: 5.1rem;
        transform: translate(-56%, 0) rotate(-7deg);
      }

      .note-panel {
        background-color: var(--note-panel);
      }

      .note-surface {
        background-color: var(--note-surface);
      }

      .note-accent {
        background-color: var(--note-accent);
      }

      .note-chip {
        background-color: var(--note-chip);
      }

      .note-inset {
        background-color: var(--note-inset);
      }

      .note-row {
        background-color: var(--note-row);
      }

      .note-muted {
        color: var(--note-muted);
      }

      .note-shell[data-note-theme="sun"] {
        --note-bg: #ffe793;
        --note-surface: #fff6ca;
        --note-panel: #fffdf0;
        --note-accent: #f9d258;
        --note-chip: #ffebb0;
        --note-inset: #fff1b7;
        --note-row: #fff9e2;
        --note-tape: rgba(255, 151, 124, 0.8);
      }

      .note-shell[data-note-theme="lavender"] {
        --note-bg: #e9ddff;
        --note-surface: #f5efff;
        --note-panel: #fcf9ff;
        --note-accent: #cab2ff;
        --note-chip: #e4d6ff;
        --note-inset: #f6f0ff;
        --note-row: #efe4ff;
        --note-tape: rgba(167, 196, 255, 0.8);
      }

      .note-shell[data-note-theme="plum"] {
        --note-bg: #bc96ff;
        --note-surface: #ceb0ff;
        --note-panel: #e2d0ff;
        --note-accent: #8f63ef;
        --note-chip: #d9c0ff;
        --note-inset: #c8a6ff;
        --note-row: #eadfff;
        --note-tape: rgba(255, 203, 175, 0.82);
      }

      .note-shell[data-note-theme="mint"] {
        --note-bg: #c7f5d2;
        --note-surface: #e9fff0;
        --note-panel: #fbfffc;
        --note-accent: #7ce29a;
        --note-chip: #c6f4d6;
        --note-inset: #f2fff5;
        --note-row: #ddfbe6;
        --note-tape: rgba(112, 221, 192, 0.8);
      }

      .note-shell[data-note-theme="blush"] {
        --note-bg: #ffd9e4;
        --note-surface: #fff0f5;
        --note-panel: #fffafc;
        --note-accent: #ff9ab8;
        --note-chip: #ffc8d7;
        --note-inset: #fff3f7;
        --note-row: #ffe4ed;
        --note-tape: rgba(255, 198, 129, 0.78);
      }

      .note-shell[data-note-theme="cobalt"] {
        --note-bg: #abc4ff;
        --note-surface: #dce7ff;
        --note-panel: #f1f5ff;
        --note-accent: #5d83f9;
        --note-chip: #c6d7ff;
        --note-inset: #edf3ff;
        --note-row: #d5e2ff;
        --note-tape: rgba(255, 214, 118, 0.8);
      }

      .note-shell[data-note-theme="peach"] {
        --note-bg: #ffd6b3;
        --note-surface: #ffe8d4;
        --note-panel: #fff5ee;
        --note-accent: #ffab6b;
        --note-chip: #ffc89e;
        --note-inset: #ffefe2;
        --note-row: #ffdfc8;
        --note-tape: rgba(255, 154, 184, 0.78);
      }

      .note-shell[data-note-theme="light-peach"] {
        --note-bg: #fff0df;
        --note-surface: #fff6e6;
        --note-panel: #fffaf0;
        --note-accent: #ffbf80;
        --note-chip: #fff3e6;
        --note-inset: #fffdf8;
        --note-row: #fff3e0;
        --note-tape: rgba(255, 184, 140, 0.78);
      }

      .page-tab-sticker {
        position: relative;
        display: inline-flex;
        align-items: center;
        max-width: 100%;
        min-height: 1.95rem;
        padding: 0.42rem 0.85rem 0.4rem 1.15rem;
        background: rgba(253, 202, 64, 0.78);
        clip-path: polygon(0.95rem 0, 100% 0, 100% 100%, 0.95rem 100%, 0 50%);
        box-shadow: 0 0.18rem 0 rgba(8, 7, 8, 0.14), 0.18rem 0.26rem 0 rgba(8, 7, 8, 0.12);
      }

      .scrapbook-btn--left {
        --sb-rest-rotate: -0.9deg;
        --sb-hover-rotate: 0.5deg;
      }

      .scrapbook-btn--right {
        --sb-rest-rotate: 0.9deg;
        --sb-hover-rotate: -0.5deg;
      }

      .scrapbook-btn--flat {
        --sb-rest-rotate: 0deg;
        --sb-hover-rotate: 0.35deg;
      }

      .scrapbook-btn--regular {
        --sb-lift-x: -1px;
        --sb-lift-y: -2px;
      }

      .scrapbook-btn--compact {
        --sb-lift-x: -0.75px;
        --sb-lift-y: -1.5px;
      }

      .scrapbook-btn--icon {
        --sb-lift-x: -0.5px;
        --sb-lift-y: -1px;
      }

      .scrapbook-btn--sm {
        --sb-base-shadow-x: 2px;
        --sb-base-shadow-y: 2px;
        --sb-hover-shadow-x: 4px;
        --sb-hover-shadow-y: 4px;
      }

      .scrapbook-btn--md {
        --sb-base-shadow-x: 4px;
        --sb-base-shadow-y: 4px;
        --sb-hover-shadow-x: 7px;
        --sb-hover-shadow-y: 7px;
      }

      .scrapbook-btn--lg {
        --sb-base-shadow-x: 6px;
        --sb-base-shadow-y: 6px;
        --sb-hover-shadow-x: 9px;
        --sb-hover-shadow-y: 9px;
      }
    </style>
  </head>
  <body class="flex min-h-screen flex-col bg-surface bg-grid font-sans text-secondary">
    <!-- Scattered nav -->
    <nav class="relative mx-auto w-full max-w-6xl px-6 pb-2 pt-6">
      <div class="flex w-full items-center justify-between gap-4">
        <BrandLink
          currentPathname={Astro.url.pathname}
          client:load
          className={cn(
            scrapbookButton({ tone: "warm", size: "compact", tilt: "left", depth: "sm" }),
            "inline-block shrink-0 border-3 border-secondary bg-tertiary px-4 py-2 font-bold uppercase tracking-tight",
          )}
        />
        <div class="ml-auto flex min-w-0 items-center justify-end gap-2 self-center">
          <slot name="nav" />
        </div>
      </div>
    </nav>

    <main class="mx-auto w-full max-w-6xl flex-1 px-6 py-6">
      <slot />
    </main>

    <TearStrip>
      <Footer />
    </TearStrip>

    <script>
      const COLORS = [
        { bg: "#3772FF", text: "#FFFFFF" }, // primary blue
        { bg: "#080708", text: "#FFFFFF" }, // secondary black
        { bg: "#FDCA40", text: "#080708" }, // tertiary yellow
        { bg: "#7C3AED", text: "#FFFFFF" }, // purple
        { bg: "#F87171", text: "#080708" }, // red
        { bg: "#34D399", text: "#080708" }, // green
      ];

      const DIRECTIONS = [
        "slide-from-left",
        "slide-from-right",
        "slide-from-top",
        "slide-from-bottom",
      ];

      function isInteractiveButton(el: Element): el is HTMLElement {
        if (!(el instanceof HTMLElement) || el.dataset.noClickOverlay === "true") {
          return false;
        }

        return el.classList.contains("scrapbook-btn");
      }

      document.addEventListener("click", (e) => {
        const target = (e.target as HTMLElement).closest("button, a");
        if (!target || !isInteractiveButton(target)) return;

        // Pick random color and direction
        const color = COLORS[Math.floor(Math.random() * COLORS.length)];
        const direction = DIRECTIONS[Math.floor(Math.random() * DIRECTIONS.length)];

        // Press down effect
        target.classList.add("btn-pressing");

        // Ensure the button can contain the overlay
        const prevOverflow = target.style.overflow;
        const prevPosition = target.style.position;
        target.style.overflow = "hidden";
        if (getComputedStyle(target).position === "static") {
          target.style.position = "relative";
        }

        // Wrap existing children in a z-index layer so text stays on top
        const children = Array.from(target.childNodes);
        const textWrap = document.createElement("span");
        textWrap.className = "click-overlay-text";
        textWrap.style.display = "contents";
        children.forEach((child) => textWrap.appendChild(child));
        target.appendChild(textWrap);

        // Create the sliding overlay
        const overlay = document.createElement("span");
        overlay.className = "click-overlay";
        overlay.style.backgroundColor = color.bg;
        overlay.style.animation = `${direction} 0.3s ease-out forwards`;
        target.appendChild(overlay);

        // Change text color for legibility
        const prevColor = target.style.color;
        target.style.color = color.text;

        // Clean up after animation
        const cleanup = () => {
          target.classList.remove("btn-pressing");
          target.style.overflow = prevOverflow;
          target.style.position = prevPosition;
          target.style.color = prevColor;

          // Unwrap the text wrapper
          if (textWrap.parentNode === target) {
            while (textWrap.firstChild) {
              target.insertBefore(textWrap.firstChild, textWrap);
            }
            textWrap.remove();
          }
          overlay.remove();
        };

        overlay.addEventListener("animationend", () => {
          setTimeout(cleanup, 150);
        });

        // Safety timeout in case animationend doesn't fire
        setTimeout(cleanup, 600);
      });
    </script>
  </body>
</html>
