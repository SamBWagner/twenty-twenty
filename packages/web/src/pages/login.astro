---
import Layout from "../layouts/Layout.astro";
import LoginScreen from "../components/react/LoginScreen";

const redirect = Astro.url.searchParams.get("redirect") || "";
const error = Astro.url.searchParams.get("error") || "";
const details = Astro.url.searchParams.get("details") || "";
---

<Layout title="Sign In">
  <LoginScreen redirect={redirect} error={error} details={details} client:load />
</Layout>
