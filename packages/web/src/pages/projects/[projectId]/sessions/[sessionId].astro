---
import Layout from "../../../../layouts/Layout.astro";
import AuthBlockedState from "../../../../components/AuthBlockedState.astro";
import SessionView from "../../../../components/react/SessionView";

const auth = Astro.locals.auth;
if (auth.state === "anonymous") return Astro.redirect("/login");
const user = auth.user;

const { projectId, sessionId } = Astro.params;
---

<Layout title="Session">
  {auth.state === "authenticated" && user ? (
    <SessionView sessionId={sessionId!} projectId={projectId!} userId={user.id} client:load />
  ) : (
    <AuthBlockedState auth={auth} />
  )}
</Layout>
