---
import { cn, scrapbookButton } from "../lib/button-styles";
import type { RequestAuthResult } from "../lib/auth";

interface Props {
  auth: RequestAuthResult;
  actionHref?: string;
  actionLabel?: string;
}

const {
  auth,
  actionHref = "/",
  actionLabel = "Go Home",
} = Astro.props;

const retryMessage = auth.retryAfterSeconds
  ? `Try again in about ${auth.retryAfterSeconds} second${auth.retryAfterSeconds === 1 ? "" : "s"}.`
  : "Try again in a few moments.";

const title = auth.state === "rate_limited"
  ? "Too Many Requests"
  : "Session Check Failed";

const message = auth.state === "rate_limited"
  ? `We couldn't verify your session right now because the app is throttling requests. ${retryMessage}`
  : "We couldn't confirm your session right now. Refresh the page in a moment and try again.";
---

<div class="mx-auto max-w-xl py-16">
  <div class="rotate-[-0.4deg] border-4 border-secondary bg-white p-8 shadow-brutal-lg">
    <p class="text-xs font-bold uppercase tracking-[0.18em] text-secondary/45">
      Temporary Interruption
    </p>
    <h2 class="mt-3 text-3xl font-bold uppercase">{title}</h2>
    <p class="mt-4 text-base font-medium text-secondary/70">
      {message}
    </p>
    <a
      href={actionHref}
      class={cn(
        scrapbookButton({ tone: "primary", size: "regular", tilt: "left", depth: "md" }),
        "mt-6 inline-block border-3 border-secondary bg-primary px-6 py-3 font-bold uppercase text-white",
      )}
    >
      {actionLabel}
    </a>
  </div>
</div>
