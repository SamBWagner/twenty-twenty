---
import Layout from "../../layouts/Layout.astro";
import AuthBlockedState from "../../components/AuthBlockedState.astro";
import JoinSession from "../../components/react/JoinSession";

const auth = Astro.locals.auth;
const { token } = Astro.params;

if (auth.state === "anonymous") {
  return Astro.redirect(`/login?redirect=/join/${token}`);
}
---

<Layout title="Join Retro">
  {auth.state === "authenticated" ? (
    <JoinSession token={token!} client:load />
  ) : (
    <AuthBlockedState auth={auth} />
  )}
</Layout>
