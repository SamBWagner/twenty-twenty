---
import Layout from "../layouts/Layout.astro";
import { cn, scrapbookButton } from "../lib/button-styles";
---

<Layout title="Welcome">
  <div class="relative py-12">
    <div aria-hidden="true" class="absolute top-8 right-12 hidden border-3 border-secondary bg-primary text-secondary px-3 py-1 font-mono text-xs font-bold rotate-[8deg] sm:block">
      v1.0
    </div>
    <div aria-hidden="true" class="absolute top-32 right-24 hidden text-6xl rotate-[15deg] select-none sm:block">
      ✦
    </div>
    <div aria-hidden="true" class="absolute bottom-20 left-8 hidden text-4xl rotate-[-10deg] text-primary select-none sm:block">
      ★
    </div>
    <div aria-hidden="true" class="absolute top-4 left-[40%] hidden h-3 w-16 rotate-[-3deg] border-2 border-secondary bg-tertiary/60 sm:block"></div>

    <div class="relative max-w-2xl mx-auto text-center">
      <div class="mb-2 inline-block">
        <h1 class="text-6xl font-bold uppercase leading-[0.9] text-stroke sm:text-7xl">
          <span class="text-tertiary">Twenty</span><br />
          <span class="text-primary">Twenty</span>
        </h1>
      </div>

      <div class="tape mx-auto mt-8 mb-10 max-w-md border-3 border-secondary bg-white p-5 rotate-[1deg]">
        <p class="text-lg font-medium leading-relaxed">
          Hindsight is 20/20. Run retros with <span class="bg-tertiary px-1 font-bold">real accountability</span> — ideation, voting, actions, and follow-through.
        </p>
      </div>

      <a
        href="/auth/signin"
        class={cn(
          scrapbookButton({ tone: "secondary", size: "regular", tilt: "left", depth: "lg" }),
          "group inline-flex max-w-full items-center justify-center gap-2 border-4 border-secondary bg-secondary px-6 py-4 text-lg font-bold uppercase text-white sm:px-10 sm:py-5 sm:text-xl",
        )}
      >
        Sign in with GitHub
        <span class="inline-block transition-transform group-hover:translate-x-1">→</span>
      </a>

      <div class="mt-12 flex flex-col items-center justify-center gap-4 sm:flex-row sm:gap-6">
        <div class="border-3 border-secondary bg-green-300 px-4 py-2 font-bold text-sm uppercase rotate-[-3deg]">
          ✓ What went well
        </div>
        <div class="border-3 border-secondary bg-red-300 px-4 py-2 font-bold text-sm uppercase rotate-[2deg]">
          ✗ What didn't
        </div>
        <div class="border-3 border-secondary bg-primary px-4 py-2 font-bold text-sm uppercase text-secondary rotate-[-1deg]">
          → Take action
        </div>
      </div>
    </div>
  </div>

  <script is:inline define:vars={{ explicitApiUrl: import.meta.env.PUBLIC_API_URL || "" }}>
    function getSessionApiBaseUrl() {
      if (explicitApiUrl) return explicitApiUrl;

      const url = new URL(window.location.origin);
      const isLocalDevHost = url.hostname === "localhost" || url.hostname === "127.0.0.1";
      if (isLocalDevHost && url.port === "4321") {
        url.port = "3001";
      }

      return url.origin;
    }

    fetch(`${getSessionApiBaseUrl()}/api/v1/auth/session`, { credentials: "include" })
      .then((res) => res.json())
      .then((data) => {
        if (data?.viewer) {
          window.location.href = "/projects";
        }
      })
      .catch(() => {});
  </script>
</Layout>
